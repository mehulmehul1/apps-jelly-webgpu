{
  "name": "jellyfish-webgpu",
  "version": "0.1.0",
  "description": "Jellyfish WebGPU TSL Port - Standalone development app",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "fxhash:dev": "npm run build && cd dist && npx fxhash dev",
    "fxhash:build": "npm run build && cd dist && npx fxhash build"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.0",
    "lucide-react": "^0.563.0",
    "particulate": "^0.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.180.0",
    "tweakpane": "^4.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.180.0",
    "@vitejs/plugin-react": "^5.1.3",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
